# Server
PORT=3001
NODE_ENV=development

# Database — local Postgres OR Supabase (see docs/DEPLOYMENT.md)
# App/runtime (Supabase): Transaction pooler, port 6543, ?pgbouncer=true
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations (Supabase): Session pooler, port 5432 on pooler host (not db.*.supabase.co — avoids P1001 / IPv6)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# Local only: use same URL for both, or localhost if using `supabase start`

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Admin (initial seed)
ADMIN_EMAIL=admin@raafat.digital
ADMIN_PASSWORD=change-me-on-first-login

# Email — Resend (preferred)
RESEND_API_KEY=re_your_api_key
RESEND_FROM="RAAFAT-DIGITAL <hello@raafat.digital>"
NOTIFICATION_EMAIL=hello@raafat.digital

# Email — Gmail SMTP (fallback if RESEND_API_KEY is unset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RAAFAT-DIGITAL <hello@raafat.digital>"

# Frontend URL (for CORS) — set to Vercel production URL on Render
FRONTEND_URL=http://localhost:5173

# Cloudinary (server-side deletes; uploads happen in the browser)
# Dashboard: Settings → Upload → Add upload preset (unsigned)
#   folder: raafat-digital/uploads, formats: jpg/png/webp/gif, max file size ~5MB
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
